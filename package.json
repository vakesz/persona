{
  "name": "persona",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm i18n:compile && tsc -b && vite build",
    "preview": "vite preview",
    "convex": "convex dev",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "NODE_OPTIONS='--disable-warning=DEP0205' knip --config config/knip.json",
    "cf:image:dev": "wrangler dev --config workers/image-api/wrangler.jsonc",
    "cf:image:deploy": "wrangler deploy --config workers/image-api/wrangler.jsonc",
    "i18n:extract": "lingui extract --config config/lingui.config.ts",
    "i18n:compile": "lingui compile --typescript --config config/lingui.config.ts",
    "check": "pnpm i18n:compile && pnpm typecheck && pnpm lint && pnpm format:check && pnpm knip",
    "cf:image:types": "wrangler types --config workers/image-api/wrangler.jsonc"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.92",
    "@lingui/core": "^6.1.0",
    "@lingui/react": "^6.1.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tanstack/react-router": "^1.170.8",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.39.1",
    "konva": "^10.3.0",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-konva": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lingui/cli": "^6.1.0",
    "@lingui/format-po": "^6.1.0",
    "@lingui/swc-plugin": "^6.2.0",
    "@lingui/vite-plugin": "^6.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/router-plugin": "^1.168.11",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "knip": "^6.14.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^8.0.14",
    "wrangler": "^4.94.0"
  }
}
