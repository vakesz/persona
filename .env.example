# Convex deployment URL — written automatically by `npx convex dev` into
# .env.local. Copy this file to .env.local only if you need to override it.
VITE_CONVEX_URL=

# Convex backend env vars. These belong on the Convex deployment, not in
# .env.local — set them with `npx convex env set NAME value`. Listed here so
# new contributors know what to provision.
#
#   CONVEX_CF_IMAGE_WORKER_URL    — optional; switches baseline/render image jobs to Cloudflare Workers AI.
#   CONVEX_CF_IMAGE_WORKER_SECRET — required when CONVEX_CF_IMAGE_WORKER_URL is set.
#   CONVEX_CF_IMAGE_MODEL         — optional; default: @cf/black-forest-labs/flux-2-dev.
#   CONVEX_CF_STYLIST_MODEL       — optional; default: @cf/meta/llama-3.2-11b-vision-instruct.
#
# Cloudflare Worker secret. Set with:
#   pnpm wrangler secret put IMAGE_API_SECRET --config workers/image-api/wrangler.jsonc
